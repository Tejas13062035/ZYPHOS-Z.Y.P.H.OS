# Z.Y.P.H.O.S Environment Variables
# Copy this file to .env and fill in your own keys
# NEVER commit .env to git — it's already in .gitignore

# LLM Providers (Cerebras is default/primary)
CEREBRAS_API_KEY=your_key_here          # free at inference.cerebras.ai
GEMINI_API_KEY=your_key_here            # free at aistudio.google.com
GROQ_API_KEY=your_key_here              # free at console.groq.com

# Weather
OPENWEATHER_API_KEY=your_key_here       # free at openweathermap.org

# News
NEWS_API_KEY=your_key_here              # free at newsapi.org

# NASA
NASA_API_KEY=your_key_here              # free at api.nasa.gov

# GitHub (for github_stats plugin)
GITHUB_TOKEN=your_token_here            # github.com/settings/tokens (public_repo scope only)

# REST Countries (optional — falls back to Wikipedia if not set)
RESTCOUNTRIES_API_KEY=your_key_here     # restcountries.com

# Spotify (optional — requires Premium for playback control)
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
